# Copy this file to config.env and fill in the token.
# Do not commit or share a filled config.env.

MATTER_TOKEN=
API_BASE_URL=https://api.getmatter.com/public/v1
OUTPUT_DIR=/mnt/onboard/Matter
STATE_PATH=/mnt/onboard/.adds/matter/state.json
LOG_PATH=/mnt/onboard/.adds/matter/matter.log
CA_CERT_FILE=/mnt/onboard/.adds/matter/cacert.pem

# Matter filters.
SYNC_STATUS=queue
CONTENT_TYPES=article,newsletter
# Maximum number of changed article bodies to fetch in one run. Metadata is
# still scanned for the full configured Matter view so stale EPUBs can be
# removed when items leave the queue.
MAX_ITEMS_PER_SYNC=50

# Automatic sync loop.
AUTO_SYNC_ENABLED=1
SYNC_INTERVAL_MINUTES=60
AUTO_CONNECT_WIFI=1
NETWORK_WAIT_SECONDS=180

# Trigger a Kobo library import after new EPUBs are written.
# NickelDBus/qndb is bundled in this installer. If qndb does not load on a
# future firmware, sync still writes files.
TRIGGER_KOBO_RESCAN=1
